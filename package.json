{
  "name": "aipks",
  "private": true,
  "version": "0.1.0",
  "description": "AI Personal Knowledge System",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "lint": "turbo run lint",
    "format": "prettier --write \"packages/**/*.{ts,tsx,json}\"",
    "aipks": "node packages/cli/dist/index.js"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.28.1",
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild", "hnswlib-node", "sharp"]
  }
