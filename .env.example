# Required
OPENAI_API_KEY=sk-...

# AI Models (optional, these are the defaults)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# Integrations (optional)
NOTION_API_KEY=secret_...
GITHUB_TOKEN=ghp_...

# Server (optional)
API_PORT=3001

# Data paths (optional, defaults shown)
VECTOR_STORE_PATH=./data/vector-store
DB_PATH=./data/db/aipks.sqlite
BRAIN_FOLDER=./brain
